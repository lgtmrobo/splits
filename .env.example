# ============================================================
# Splits — Environment Variables
# ============================================================
# Copy to .env and fill in. Production needs all of these (except
# DEV_AUTH_BYPASS, which is local only).

# ---- Supabase ----
# From your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Strava ----
# From https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Any random string — used by Strava to verify your webhook subscription.
# Generate with: openssl rand -hex 16
STRAVA_WEBHOOK_VERIFY_TOKEN=

# ---- WHOOP (optional, recommended) ----
# From https://developer-dashboard.whoop.com
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=

# ---- Anthropic ----
# From https://console.anthropic.com
ANTHROPIC_API_KEY=

# ---- App ----
# Used for OAuth redirect URIs and webhook callback URL.
# Local: http://localhost:3000 — prod: https://splits.yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Checked in /api/cron/* handlers. Vercel Cron sends this as a Bearer token.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# The single user's email. Anyone else who signs in with Google gets bounced.
ALLOWED_EMAIL=

# Athlete's timezone (used to compute "today" correctly when the server runs in UTC).
# IANA TZ name, e.g. America/Los_Angeles, America/New_York, Europe/London.
APP_TIMEZONE=America/Los_Angeles

# ---- Dev only ----
# Set to "true" locally to skip Google login and use the service-role
# Supabase client. NEVER set in production.
DEV_AUTH_BYPASS=
